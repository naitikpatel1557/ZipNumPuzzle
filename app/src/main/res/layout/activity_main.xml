<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#FAFAFA"
    android:id="@+id/main">

    <LinearLayout
        android:id="@+id/screenMainMenu"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="visible">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ZIP PUZZLE"
            android:textSize="42sp"
            android:textStyle="bold"
            android:textColor="#E91E63"
            android:layout_marginBottom="64dp"/>

        <Button
            android:id="@+id/btnPlay"
            android:layout_width="200dp"
            android:layout_height="60dp"
            android:text="PLAY"
            android:textSize="24sp"
            android:backgroundTint="#000000"
            android:textColor="#FFFFFF" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnShop"
            android:layout_width="200dp"
            android:layout_height="60dp"
            android:text="🪙 0 | SHOP"
            android:textSize="18sp"
            android:layout_marginTop="16dp"
            app:backgroundTint="#FFB300"
            android:textColor="#000000" />
    </LinearLayout>

    <!-- Result Screen Overlay (Hidden by default) -->
    <include
            android:id="@+id/screenResults"
            layout="@layout/activity_result"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />

    <LinearLayout
        android:id="@+id/screenDifficulty"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:background="#FAFAFA"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select Difficulty"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A"
            android:layout_marginBottom="48dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEasy"
            android:layout_width="250dp"
            android:layout_height="65dp"
            android:text="EASY (5x5)"
            android:textSize="20sp"
            android:layout_marginBottom="16dp"
            app:cornerRadius="32dp"
            app:backgroundTint="#4CAF50" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMedium"
            android:layout_width="250dp"
            android:layout_height="65dp"
            android:text="MEDIUM (6x6)"
            android:textSize="20sp"
            android:layout_marginBottom="16dp"
            app:cornerRadius="32dp"
            app:backgroundTint="#FF9800" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnHard"
            android:layout_width="250dp"
            android:layout_height="65dp"
            android:text="HARD (8x8)"
            android:textSize="20sp"
            android:layout_marginBottom="48dp"
            app:cornerRadius="32dp"
            app:backgroundTint="#F44336" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBackFromDifficulty"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← Back"
            android:textColor="#757575" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/screenLevelSelect"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#F4F5F7"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="24dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Select Level"
                android:textColor="#1A1A1A"
                android:textSize="34sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black" />
        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal">
                <GridLayout
                android:id="@+id/levelGrid"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:columnCount="3"
                android:paddingBottom="32dp"
                android:alignmentMode="alignBounds">
            </GridLayout>

            </LinearLayout>
        </ScrollView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBackToMenu"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="← Back to Menu"
            android:textColor="#757575"
            android:textSize="16sp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="32dp"
            android:textAllCaps="false"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/screenGame"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#FAFAFA"
        android:visibility="gone">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBackFromGame"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:text="←"
                android:textSize="28sp"
                android:textColor="#000000"
                android:minWidth="48dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:padding="0dp"/>

            <TextView
                android:id="@+id/tvLevel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/btnBackFromGame"
                android:layout_centerVertical="true"
                android:layout_marginStart="8dp"
                android:text="Level 1"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#000000" />

            <TextView
                android:id="@+id/tvTimer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toStartOf="@id/btnSettings"
                android:layout_centerVertical="true"
                android:layout_marginEnd="16dp"
                android:text="⏱ 0:00"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#000000" />

            <ImageButton
                android:id="@+id/btnSettings"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_preferences"
                app:tint="#000000" />
        </RelativeLayout>

        <com.numberpath.myapplication.ZipPuzzleView
            android:id="@+id/puzzleBoard"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_margin="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="16dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnReset"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:text="Reset"
                android:textColor="#E91E63"
                app:strokeColor="#E91E63" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Hint (25🪙)"
                android:textColor="#FFFFFF"
                app:backgroundTint="#E91E63" />

        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#E0E0E0"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <RelativeLayout
                    android:id="@+id/layoutHowToPlayHeader"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:text="How to play"
                        android:textColor="#1A1A1A"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:id="@+id/ivArrow"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:src="@android:drawable/ic_menu_more"
                        android:rotation="90"
                        app:tint="#1A1A1A" />
                </RelativeLayout>

                <LinearLayout
                    android:id="@+id/layoutHowToPlayContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="8dp"
                    android:baselineAligned="false"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:cardBackgroundColor="#E91E63"
                            app:cardCornerRadius="14dp"
                            app:strokeWidth="0dp"
                            android:layout_marginBottom="12dp">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:padding="4dp">

                                <com.google.android.material.card.MaterialCardView
                                    android:layout_width="24dp" android:layout_height="24dp"
                                    app:cardBackgroundColor="#000000" app:cardCornerRadius="12dp"
                                    app:strokeWidth="0dp">
                                    <TextView android:layout_width="match_parent" android:layout_height="match_parent" android:text="1" android:textColor="#FFFFFF" android:gravity="center" android:textSize="12sp" android:textStyle="bold"/>
                                </com.google.android.material.card.MaterialCardView>

                                <com.google.android.material.card.MaterialCardView
                                    android:layout_width="24dp" android:layout_height="24dp"
                                    android:layout_marginStart="4dp"
                                    app:cardBackgroundColor="#000000" app:cardCornerRadius="12dp"
                                    app:strokeWidth="0dp">
                                    <TextView android:layout_width="match_parent" android:layout_height="match_parent" android:text="2" android:textColor="#FFFFFF" android:gravity="center" android:textSize="12sp" android:textStyle="bold"/>
                                </com.google.android.material.card.MaterialCardView>

                                <com.google.android.material.card.MaterialCardView
                                    android:layout_width="24dp" android:layout_height="24dp"
                                    android:layout_marginStart="4dp"
                                    app:cardBackgroundColor="#000000" app:cardCornerRadius="12dp"
                                    app:strokeWidth="0dp">
                                    <TextView android:layout_width="match_parent" android:layout_height="match_parent" android:text="3" android:textColor="#FFFFFF" android:gravity="center" android:textSize="12sp" android:textStyle="bold"/>
                                </com.google.android.material.card.MaterialCardView>
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Connect the\ndots in order"
                            android:textAlignment="center"
                            android:textSize="14sp"
                            android:textColor="#424242"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            app:cardCornerRadius="8dp"
                            app:strokeColor="#D0D0D0"
                            app:strokeWidth="2dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="#FFFFFF"
                            android:layout_marginBottom="8dp">

                            <RelativeLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:padding="6dp">
                                <View android:layout_width="8dp" android:layout_height="match_parent" android:layout_alignParentStart="true" android:background="#E91E63" />
                                <View android:layout_width="match_parent" android:layout_height="8dp" android:layout_alignParentBottom="true" android:background="#E91E63" />
                                <View android:layout_width="8dp" android:layout_height="18dp" android:layout_alignParentEnd="true" android:layout_alignParentBottom="true" android:background="#E91E63" />
                            </RelativeLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Fill every\ncell"
                            android:textAlignment="center"
                            android:textSize="14sp"
                            android:textColor="#424242"/>
                    </LinearLayout>

                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>


</FrameLayout>
